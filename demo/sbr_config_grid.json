{
  "scene": {
    "obj_file": "demo/Scene/meeting.obj",
    "material_map_file": "demo/Material/material_map-meeting.json",
    "material_csv_file": ""
  },
  "sbr": {
    "center_frequency_hz": 2.4e9,
    "ray_count": 2000000,
    "max_ray_depth": 8,
    "max_reflection_count": 4,
    "max_transmission_count": 2,
    "max_diffraction_count": 1,
    "diffraction_rays_per_event": 4,
    "wedge_max_distance_m": 5.0,
    "wedge_max_candidates": 8,
    "ray_power_threshold_dB": -160.0,
    "tx_power_dBm": 0.0
  },
  "receiver": {
    "rx_sphere_radius_m": 0.5,
    "enable_dynamic_rx_radius": true,
    "ray_tube_radius_scale": 0.5,
    "ray_tube_min_radius_m": 0.1,
    "ray_tube_max_radius_m": 2.0
  },
  "postprocess": {
    "enable_path_dedup": true,
    "enable_path_similarity_pruning": true,
    "path_similarity_length_tol_m": 0.05,
    "path_top_n_per_rx": 5,
    "store_paths": true
  },
  "tx": { "x": 10.0, "y": 2.0, "z": -2.0 },
  "rx_mode": "grid",
  "rx_grid": {
    "x_min": 3.0, "x_max": 17.0, "x_step": 1.0,
    "y_min": 0.5, "y_max": 2.5, "y_step": 2.0,
    "z_min": -18.0, "z_max": -2.0, "z_step": 1.0
  },
  "output": {
    "result_json": "output/sbr_result_grid.json",
    "result_csv": "output/sbr_paths_grid.csv"
  }
}
